.credits-modal-card {
  width: 620rpx;
}

.credits-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.credits-label {
  font-size: 28rpx;
  color: var(--ink-medium);
}

.credits-value {
  font-size: 28rpx;
  color: var(--ink-deep);
  font-weight: 600;
}

.credits-deficit-row .credits-value {
  font-size: 32rpx;
}

.vip-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  margin: 16rpx 0 0;
  background: linear-gradient(135deg, #fdf6ec, #fcefd4);
  border-radius: 12rpx;
}

.vip-banner-text {
  font-size: 24rpx;
  color: #b8860b;
  font-weight: 500;
}

.vip-banner-arrow {
  font-size: 24rpx;
  color: #b8860b;
}

.credits-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
