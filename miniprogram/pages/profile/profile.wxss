.page-container {
  min-height: 100vh;
  background-color: var(--paper-100);
  padding-bottom: 80rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xxl) 0 var(--spacing-xl);
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-color);
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--paper-200);
  color: var(--ink-light);
  font-size: 56rpx;
}

.camera-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: var(--ink-deep);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-icon {
  color: var(--paper-50);
  font-size: 28rpx;
  font-weight: bold;
}

.avatar-hint {
  font-size: 22rpx;
  color: var(--ink-light);
  margin-top: var(--spacing-sm);
}

/* 表单区域 */
.form-section {
  padding: 0 var(--spacing-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.form-item {
  background: var(--paper-50);
  padding: var(--spacing-lg);
}

.form-label-row {
  margin-bottom: 8rpx;
}

.form-label {
  font-size: 22rpx;
  color: var(--ink-light);
}

.form-value-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-value {
  font-size: 32rpx;
  color: var(--ink-deep);
}

.form-chevron {
  font-size: 24rpx;
  color: var(--ink-light);
}

/* 保存按钮 */
.save-section {
  padding: var(--spacing-xxl) var(--spacing-lg);
}

.save-btn {
  background: var(--ink-deep);
  padding: var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.save-btn.disabled {
  opacity: 0.4;
}

.save-btn-text {
  font-size: 32rpx;
  color: var(--paper-50);
  font-weight: 600;
}

/* 头像选择弹窗 */
.avatar-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.avatar-picker-popup {
  width: 100%;
  background: var(--paper-50);
  border-radius: 24rpx 24rpx 0 0;
  padding: var(--spacing-lg) var(--spacing-lg) 60rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.avatar-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.avatar-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink-deep);
}

.avatar-picker-close {
  font-size: 40rpx;
  color: var(--ink-light);
  padding: 0 var(--spacing-sm);
}

.avatar-picker-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-lg);
}

.avatar-picker-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: var(--spacing-sm);
  border-radius: 16rpx;
  border: 3rpx solid transparent;
}

.avatar-picker-item.selected {
  border-color: var(--ink-deep);
  background: var(--paper-200);
}

.avatar-picker-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar-picker-label {
  font-size: 22rpx;
  color: var(--ink-light);
}

/* 微信头像按钮（重置 button 默认样式） */
.wechat-avatar-btn {
  background: transparent;
  border: 3rpx solid transparent;
  margin: 0;
  padding: var(--spacing-sm);
  line-height: 1;
  min-height: 0;
  font-size: inherit;
  color: inherit;
  box-sizing: border-box;
}

.wechat-avatar-btn::after {
  display: none;
}

.wechat-avatar-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.wechat-icon-text {
  color: #fff;
  font-size: 48rpx;
  font-weight: 600;
}

/* 昵称编辑弹窗 */
.name-editor-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.name-editor-popup {
  width: 600rpx;
  background: var(--paper-50);
  border-radius: 16rpx;
  padding: var(--spacing-xl);
}

.name-editor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.name-editor-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink-deep);
}

.name-editor-close {
  font-size: 40rpx;
  color: var(--ink-light);
  padding: 0 var(--spacing-sm);
}

.name-editor-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  padding: 0 var(--spacing-md);
  font-size: 30rpx;
  color: var(--ink-deep);
  box-sizing: border-box;
}

.name-editor-btn {
  margin-top: var(--spacing-lg);
  background: var(--ink-deep);
  padding: var(--spacing-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
}

.name-editor-btn-text {
  font-size: 30rpx;
  color: var(--paper-50);
  font-weight: 600;
}
