<view class="page-container">
  <!-- 头像区域 -->
  <view class="avatar-section">
    <view class="avatar-wrap" bindtap="onChooseAvatar">
      <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" binderror="onAvatarLoadError" wx:if="{{avatarUrl}}"></image>
      <view class="avatar placeholder" wx:else>
        <text class="avatar-text">U</text>
      </view>
      <view class="camera-badge">
        <text class="camera-icon">+</text>
      </view>
    </view>
    <text class="avatar-hint">点击选择头像</text>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <view class="form-item ink-border" bindtap="onEditName">
      <view class="form-label-row">
        <text class="form-label">昵称</text>
      </view>
      <view class="form-value-row">
        <text class="form-value">{{name || '未设置'}}</text>
        <text class="form-chevron">></text>
      </view>
    </view>

    <picker mode="date" value="{{birthDate}}" start="1940-01-01" end="2010-12-31" bindchange="onDateChange">
      <view class="form-item ink-border">
        <view class="form-label-row">
          <text class="form-label">出生日期</text>
        </view>
        <view class="form-value-row">
          <text class="form-value">{{birthDate || '未设置'}}</text>
          <text class="form-chevron">></text>
        </view>
      </view>
    </picker>

    <picker mode="time" value="{{birthTime}}" bindchange="onTimeChange">
      <view class="form-item ink-border">
        <view class="form-label-row">
          <text class="form-label">出生时间</text>
        </view>
        <view class="form-value-row">
          <text class="form-value">{{birthTime || '未设置'}}</text>
          <text class="form-chevron">></text>
        </view>
      </view>
    </picker>

    <view class="form-item ink-border" bindtap="onEditBirthCity">
      <view class="form-label-row">
        <text class="form-label">出生城市</text>
      </view>
      <view class="form-value-row">
        <text class="form-value">{{birthCity || '未设置'}}</text>
        <text class="form-chevron">></text>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <view class="save-btn {{hasChanges ? '' : 'disabled'}}" bindtap="onSave">
      <text class="save-btn-text">保存修改</text>
    </view>
  </view>

  <!-- 头像选择弹窗 -->
  <view class="avatar-picker-mask" wx:if="{{showAvatarPicker}}" bindtap="onCloseAvatarPicker">
    <view class="avatar-picker-popup" catchtap="onNoop">
      <view class="avatar-picker-header">
        <text class="avatar-picker-title">选择头像</text>
        <text class="avatar-picker-close" bindtap="onCloseAvatarPicker">×</text>
      </view>
      <scroll-view scroll-y class="avatar-picker-scroll">
        <view class="avatar-picker-grid">
          <button
            class="avatar-picker-item wechat-avatar-btn"
            open-type="chooseAvatar"
            bindchooseavatar="onChooseWechatAvatar"
          >
            <view class="wechat-avatar-icon">
              <text class="wechat-icon-text">微</text>
            </view>
            <text class="avatar-picker-label">微信头像</text>
          </button>
          <view
            class="avatar-picker-item {{avatarUrl === item.url ? 'selected' : ''}}"
            wx:for="{{avatarOptions}}"
            wx:key="url"
            data-url="{{item.url}}"
            bindtap="onSelectAvatar"
          >
            <image class="avatar-picker-img" src="{{item.url}}" mode="aspectFill"></image>
            <text class="avatar-picker-label">{{item.label}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 昵称编辑弹窗 -->
  <view class="name-editor-mask" wx:if="{{showNameEditor}}" bindtap="onCloseNameEditor" catchtouchmove="onCloseNameEditor">
    <view class="name-editor-popup" catchtap="onNoop" catchtouchmove="onNoop">
      <view class="name-editor-header">
        <text class="name-editor-title">修改昵称</text>
        <text class="name-editor-close" bindtap="onCloseNameEditor">×</text>
      </view>
      <input
        class="name-editor-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{editingName}}"
        bindinput="onNameInput"
        bindnicknamereview="onNicknameReview"
        focus="{{showNameEditor}}"
      />
      <view class="name-editor-btn" bindtap="onConfirmName">
        <text class="name-editor-btn-text">确认</text>
      </view>
    </view>
  </view>
</view>
