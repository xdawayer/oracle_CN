/* pages/records/records.wxss - 水墨极简风格 */

.container {
  background-color: var(--paper-100);
  min-height: 100vh;
}

.record-list {
  padding: var(--spacing-lg);
}

/* 记录卡片 */
.record-card {
  background-color: var(--paper-50);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  display: flex;
  align-items: center;
  gap: var(--spacing-lg);
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-names {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.names-text {
  font-size: 30rpx;
  color: var(--ink-deep);
  font-weight: 500;
}

.relation-tag {
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  color: var(--ink-light);
  border: 1rpx solid var(--border-color);
}

.date-text {
  font-size: 22rpx;
  color: var(--ink-light);
}

.record-chevron {
  font-size: 24rpx;
  color: var(--ink-light);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xxl);
}

.empty-title {
  font-size: 30rpx;
  color: var(--ink-dark);
  margin-bottom: var(--spacing-sm);
}

.empty-desc {
  font-size: 24rpx;
  color: var(--ink-light);
  text-align: center;
  line-height: 1.6;
  margin-bottom: var(--spacing-xl);
}

.empty-btn {
  background: var(--ink-deep);
  padding: var(--spacing-md) var(--spacing-xxl);
}

.empty-btn-text {
  font-size: 28rpx;
  color: var(--paper-50);
}
